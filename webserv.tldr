v\"},                                    "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    {\".txt\", \"text/plain\"},                                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    ...                                                      "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"}                                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"If the requested file doesn't match any of the MIME types in the map, we use the default type: "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"application/octet-stream"},{"type":"text","marks":[{"type":"code"}],"text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"link","attrs":{"href":"https://developer.mozilla.org/en-US/docs/Web/HTTP/Guides/MIME_types/Common_types","target":"_blank","rel":"noopener noreferrer nofollow","class":null}},{"type":"code"}],"text":"Here"},{"type":"text","marks":[{"type":"code"}],"text":" is a list of the common MIME types used in HTTP."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b40czvixl","typeName":"shape"},{"x":2678.611409099792,"y":3254.8369928692664,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:v3JC5BJX50uWqaJwCzBoS","type":"geo","props":{"w":568,"h":1,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"m","font":"mono","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b1vVXSDLV","typeName":"shape"},{"x":2374.1017419814043,"y":1123.3069344240703,"rotation":0,"isLocked":false,"opacity":1,"meta