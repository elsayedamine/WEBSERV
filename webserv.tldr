lAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2eP77s3V","typeName":"shape"},{"x":1069.9766922879357,"y":3421.2419313356186,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:JvmBYvkZdL9PnFkNpU4CI","type":"geo","props":{"w":666.6681368847571,"h":318.12772064557157,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"af189fMV","typeName":"shape"},{"x":2979.642293650763,"y":574.6778516430991,"rotation":0.7330382858376184,"isLocked":false,"opacity":1,"meta":{},"id":"shape:3cDHM7I4qggHEt_k_91oA","type":"image","index":"b1lrzWcQl","parentId":"page:vjUhjWqdOVlf272RqSZx4","props":{"w":32.296447331617856,"h":59.819273639116204,"assetId":"asset:1442115126","playing":true,"url":"","crop":null,"flipX":false,"flipY":false,"altText":""},"typeName":"shape"},{"x":1052.3592737197355,"y":767.224917247009,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:8EdfVT1aWsRjrbhytTSzG","type":"text","props":{"color":"black","size":"m","w":389.79998779296875,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Step 1: Creating the socket"}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b05cik92V","typeName":"shape"},{"x":4190.600315323032,"y":265.70485087881525,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:W7SfU4xhinXlZs2AyddME","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Earlier we talked about the basics of creating a socket and performing I/O operations on it. But the sockets we created have three major issues:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"They cannot be reused: the same address cannot be rebound to the same socket until after some time."}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"They are blocking: performing I/O operations on them blocks the program until they are finished."}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"There can only be one: We can only wait for connection on a single socket"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"These issues need to be fixed before to make an efficient web server."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2nn0S6CV","typeName":"shape"},{"x":5805.809833812464,"y":2306.4056862755315,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:pEIuU-raFIcjqYamU4vX5","type":"geo","props":{"w":568,"h":1,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"m","font":"mono","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3LuMU0aG","typeName":"shape"},{"x":2893.9489009039735,"y":562.3851458990039,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:jrd1QbrxZuCsRvT26cO-S","type":"text","props":{"color":"black","size":"s","w":47.30117055192659,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Code"}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b1a2Izv4l","typeName":"shape"},{"x":2628.0510946177483,"y":4441.763620870621,"rotation":0,"