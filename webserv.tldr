ge:vjUhjWqdOVlf272RqSZx4","index":"adQbZVKV","typeName":"shape"},{"x":1068.8201914452964,"y":2039.386112044117,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:FCeDE-64p3w5cl2NbgvXz","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"When we talk about "},{"type":"text","marks":[{"type":"italic"}],"text":"naming"},{"type":"text","text":" a socket, we are talking about assigning a transport address to the socket. In the context of TCP/IP, this transport address is the IP await for an incoming connection address and the port. This operation is called "},{"type":"text","marks":[{"type":"italic"}],"text":"binding"},{"type":"text","text":", for which the "},{"type":"text","marks":[{"type":"bold"}],"text":"bind"},{"type":"text","text":" system call is used."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"int bind(int socket, const struct sockaddr *address, socklen_t address_len);                              "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"socket"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"This is the socket that was created earlier with the socket system call."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"address"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"This is the actual socket address structure. It is a general data structure that contains information about the address. Each address family has its own socket address structure that we can cast into a "},{"type":"text","marks":[{"type":"highlight"}],"text":"sockaddr *"},{"type":"text","text":" before passing it into the "},{"type":"text","marks":[{"type":"italic"}],"text":"bind"},{"type":"text","text":" system call. For the "},{"type":"text","marks":[{"type":"bold"}],"text":"AF_INET"},{"type":"text","text":" address family, we use "},{"type":"text","marks":[{"type":"highlight"}],"text":"sockaddr_in"},{"type":"text","text":", which is defined as such:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"struct sockaddr_in                 "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"{                                  "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    __uint8_t         sin_len;     "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    sa_family_t       sin_family;  "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    in_port_t         sin_port;    "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    struct in_addr    sin_addr;    "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    char              sin_zero[8]; "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"};                                 "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Before calling "},{"type":"text","marks":[{"type":"italic"}],"text":"bind"},{"type":"text","text":", we need to fill out this structure. The three key parts we need to set are:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"sin_family:"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The address family we used when we set up the socket. In our "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"case, it’s "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"AF_INET"},{"type":"text","text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"sin_port:"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The port number (the transport address). You can explicitly assign a transport address (port) or allow the operating system to assign one. you’ll generally pick a specific number since clients will need to know a port number to connect to."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"sin_addr:"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The address for this socket. This is just your machine’s IP address. Most of the time, we don’t care to specify a specific interface and can let the operating system use whatever it wants. The special address for this is 0.0.0.0, defined by the symbolic constant "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"INADDR_ANY"},{"type":"text","text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"address_len"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"This is simply "},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"sizeof(struct sockaddr_in)"},{"type":"text","marks":[{"type":"code"}],"text":". "},{"type":"text","text":"Since the address structure may differ based on the type of transport used, the third parameter specifies the length of that structure."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The code to bind a socket looks like this:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"#include <sys/socket.h>                                       "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"                                                              "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"struct sockaddr_in address;                                   "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"                                                              "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"memset((char"},{"type":"text","marks":[{"type":"highlight"},{"type":"italic"}],"text":" *"},{"type":"text","marks":[{"type":"highlight"}],"text":")&address, 0, sizeof(address));                                             "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"address.sin_family = AF_INET;                                 "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"address.sin_addr.s_addr = htonl(INADDR_ANY);                  "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"address.sin_port = htons(8080);                               "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"if (bind(server_fd, (struct sockaddr *)&address,               sizeof(address)) < 0) {                                       "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    perror(“bind failed”);                                    "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    return 0;                                                 "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"}                                                             "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The htonl and htons functions convert a long integer (address) and a short integer (port) respectively into a network representation."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b0Esl2UXG","typeName":"shape"},{"x":1072.1057530337912,"y":5197.509614255185,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:A8ZkH1cPuVWw3TkkNtbEt","type":"geo","props":{"w":196.39062787233294,"h":25.511091254748866,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b0bXh9V2V","typeName":"shape"},{"x":1070.526493721961,"y":4452.170362135155,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:VTMG0On5OUA2hZj_SD0p