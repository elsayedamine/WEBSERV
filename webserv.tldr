s"}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b0gz4FMHG","typeName":"shape"},{"x":4190.214922530789,"y":3383.3064507558306,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:i5I2GeCJ_piy7F4jKPomj","type":"geo","props":{"w":240.07280639666897,"h":123.24440323769659,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2x8tXuXV","typeName":"shape"},{"x":0,"y":0,"z":1,"meta":{},"id":"camera:page:ehHksvunM8m4DPXTHIE3o","typeName":"camera"},{"x":1860.6589738189775,"y":304.4023441942087,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:Zxh8LSW8amE6X8cUtLo5J","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Now that we're have a working communication endpoint, through which we can receive requests, we must understand what each request is and resolve it accordingly."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Pretty much all web servers and clients nowadays use HTTP to communicate. HTTP (Hypertext transfer protocol) is a set of standards that define how we exchange data between servers and clients. These standards have been proposed by the IETF (Internet Engineering Task Force) in what is known as an RFC."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"An RFC (Request for Comments) is a publication that describes internet standards. The initial HTTP/1.1 RFC is "},{"type":"text","marks":[{"type":"link","attrs":{"href":"http://www.rfc-editor.org/info/rfc2616","target":"_blank","rel":"noopener ugc nofollow","class":"ah if"}}],"text":"RFC2616"},{"type":"text","text":", though it was later replaced by RFCs 7230 through 7235, which were in turn replaced by RFCs 9110 through 9112."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"As of writing this roadmap, the most recent (and most widely used) standard for HTTP/1.1 is "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://datatracker.ietf.org/doc/html/rfc9112","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"RFC9112"},{"type":"text","text":", which is what we will be working off of."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b0jwRgEcV","typeName":"shape"},{"x":1074.893199600655,"y":4840.982114732959,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:-D39DZplmQ_EQGJsMTk1l","type":"geo","props":{"w":661.3005369211469,"h":196.65728748852416,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"apsdZvHV","typeName":"shape"},{"x":4253.363721823532,"y":1778.6701241406693,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:g07ZGRlZ2p4ikh4xI1XaQ","type":"geo","props":{"w":568,"h":1,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"m","font":"mono","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2j0RlgUG","typeName":"shape"},{"x":1050.8721851098414,"y":504.01023329578317,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:_nByX7iPwCNDIsqtlWH1V","type":"text","props":{"color":"black","size":"m","w":335.79998779296875,"