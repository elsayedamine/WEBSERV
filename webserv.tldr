ragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"This tells our web server to look for any requested .php or .py files in the "},{"type":"text","marks":[{"type":"bold"}],"text":"cgi-bin"},{"type":"text","text":" directory and to execute them."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3XhVpZxV","typeName":"shape"},{"x":1333.867031239949,"y":126.39475506279325,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:YcYXX0x7IVpXj0DRH4nTd","type":"text","props":{"color":"black","size":"l","w":130.60000610351562,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Part 1"}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"aCIjsxUl","typeName":"shape"},{"x":2629.308551139786,"y":2896.8411898990744,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:LpG5HvphaJk5Q-GW4PHMA","type":"geo","props":{"w":670.3335674598583,"h":224.54777637754884,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2QSzOU2O","typeName":"shape"},{"x":1853.3806435897022,"y":1390.7821357404703,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:6NjysQRqpU5McwyK-BDPQ","type":"geo","props":{"w":665.8862689510295,"h":665.0431932992591,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b135UoQul","typeName":"shape"},{"x":4191.73387999345,"y":621.7789211314471,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:SjYWuWnaR3RhRlh6kiWYr","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Let's talk about the first issue. A "},{"type":"text","marks":[{"type":"bold"}],"text":"TCP"},{"type":"text","text":"/"},{"type":"text","marks":[{"type":"bold"}],"text":"IP"},{"type":"text","text":" connection can be in one of four states; "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"LISTENING"},{"type":"text","marks":[{"type":"code"}],"text":", "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"CLOSE_WAIT"},{"type":"text","marks":[{"type":"code"}],"text":", "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"TIME_WAIT"},{"type":"text","marks":[{"type":"code"}],"text":" or "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"ESTABLISHED"},{"type":"text","marks":[{"type":"code"}],"text":". When a socket is closed locally, it does into the "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"TIME_WAIT"},{"type":"text","marks":[{"type":"code"}],"text":" state, which marks the socket as \"in use\" for a certain amount of time to make sure there are no more pending packets. You can read more about this "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://superuser.com/a/173542","target":"_blank","rel":"noopener noreferrer nofollow","class":null}},{"type":"code"}],"text":"here"},{"type":"text","marks":[{"type":"code"}],"text":" and "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://stackoverflow.com/a/337137","target":"_blank","rel":"noopener noreferrer nofollow","class":null}},{"type":"code"}],"text":"here"},{"type":"text","marks":[{"type":"code"}],"text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"In order to fix this, we use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"setsockopt"},{"type":"text","marks":[{"type":"code"}],"text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"int setsockopt(int socket, int level, int option_name, "},{"type":"hardBreak","marks":[{"type":"highlight"},{"type":"code"}]},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"       const void *option_value, socklen_t option_len);"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"/=> "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"socket"},{"type":"text","marks":[{"type":"code"}],"text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"The socket FD we would like to set the options for."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"/=> "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"level"},{"type":"text","marks":[{"type":"code"}],"text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"Tells the kernel which protocol layer the option belongs to, we use "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"SOL_SOCKET"},{"type":"text","marks":[{"type":"code"}],"text":", which corresponds to socket layer."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"/=> "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"option_name"},{"type":"text","marks":[{"type":"code"}],"text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"The option name we would like to set. In our case, we want to set the "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"SO_REUSEADDR"},{"type":"text","marks":[{"type":"code"}],"text":", which "},{"type":"text","text":"allows rebinding to an address in "},{"type":"text","marks":[{"type":"bold"}],"text":"TIME_WAIT"},{"type":"text","text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"option_value"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The value we want to set for the option. It's a void pointer because it can be anything depending on what the option is. Since "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"SO_REUSEADDR"},{"type":"text","marks":[{"type":"code"}],"text":" is a boolean option, we will use a pointer to an "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"int"},{"type":"text","marks":[{"type":"code"}],"text":" set to 1."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"/=> "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"option_len"},{"type":"text","marks":[{"type":"code"}],"text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"This is just "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"sizeof() "},{"type":"text","marks":[{"type":"code"}],"text":"the option value, it helps the call understand what the option is."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"With that, here's what our system call would look like."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"int val = 1;                                                 "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"                                                             "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"if (setsockopt(sock_fd SOL_SOCKET, SO_REUSEADDR, &val,       sizeof(int)) < 0) {                                          "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"\tperror(\"setsockopt\");                                "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"\treturn (0);                                          "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"}                                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"Now, even after closing the connection locally, or exiting from the program, we won't have to wait before rebinding the socket with the same address."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2bEUKGzt","typeName":"shape"},{"x":4180.387699868832,"y":2906.56939075813,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:JvlhmDuIVY9CCurlzfWNX","type":"text","props":{"color":"black","size":"m","w":379,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"orderedList","attrs":{"start":3,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"ty