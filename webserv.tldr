d":false,"opacity":1,"meta":{},"id":"shape:EpqAhfOBbR--r3L3buCl6","type":"text","props":{"color":"black","size":"s","w":678.1373134722685,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"We will look at every element of what makes a basic web server, implementing each element. Here's what we'll talk about:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"TCP/IP Sockets"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Non-blocking I/O"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Listening on multiple sockets"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"HTTP/1.1 protocol"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"HTTP requests"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"HTTP responses"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"HTTP Headers"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"HTTP status codes"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"MIME types"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Configuration file"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Simple and block directives"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"}}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"aAZZrLQV","typeName":"shape"},{"x":1071.470433352606,"y":2037.3187781081797,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:YHPUXXQjLopskRHpPm35W","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"When we talk about "},{"type":"text","marks":[{"type":"italic"}],"text":"naming"},{"type":"text","text":" a socket, we are talking about assigning a transport address to the socket. In the context of TCP/IP, this transport address is the IP await for an incoming connectionddress and the port. This operation is called "},{"type":"text","marks":[{"type":"italic"}],"text":"binding"},{"type":"text","text":", for which the "},{"type":"text","marks":[{"type":"bold"}],"text":"bind"},{"type":"text","text":" system call is used."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"int bind(int socket, const struct sockaddr *address, socklen_t address_len);                              "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"socket"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"This is the socket that was created earlier with the socket system call."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"address"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"This is the actual socket address structure. It is a general data structure that contains information about the address. Each address family has its own socket address structure that we can cast into a "},{"type":"text","marks":[{"type":"highlight"},{"type":"bold"}],"text":"sockaddr *"},{"type":"text","text":" before passing it into the "},{"type":"text","marks":[{"type":"italic"}],"text":"bind"},{"type":"text","text":" system call. For the "},{"type":"text","marks":[{"type":"bold"}],"text":"AF_INET"},{"type":"text","text":" address family, we use "},{"type":"text","marks":[{"type":"highlight"}],"text":"sockaddr_in"},{"type":"text","text":", which is defined as such:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"struct sockaddr_in                 "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"{                                  "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    __uint8_t         sin_len;     "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    sa_family_t       sin_family;  "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    in_port_t         sin_port;    "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    struct in_addr    sin_addr;    "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    char              sin_zero[8]; "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"};                                 "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Before calling "},{"type":"text","marks":[{"type":"italic"}],"text":"bind"},{"type":"text","text":", we need to fill out this structure. The three key parts we need to set are:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"sin_family:"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The address family we used when we set up the socket. In our "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"case, it’s "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"AF_INET"},{"type":"text","text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"sin_port:"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The port number (the transport address). You can explicitly assign a transport address (port) or allow the operating system to assign one. you’ll generally pick a specific number since clients will need to know a port number to connect to."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"sin_addr:"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The address for this socket. This is just your machine’s IP address. Most of the time, we don’t care to specify a specific interface and can let the operating system use whatever it wants. The special address for this is 0.0.0.0, defined by the symbolic constant "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"INADDR_ANY"},{"type":"text","text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"address_len"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"This is simply "},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"sizeof(struct sockaddr_in)"},{"type":"text","marks":[{"type":"code"}],"text":". "},{"type":"text","text":"Since the address structure may differ based on the type of transport used, the third parameter specifies the length of that structure."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The code to bind a socket looks like this:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"#include <sys/socket.h>                                       "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"                                                              "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"struct sockaddr_in address;                                   "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"                                                              "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"memset((char"},{"type":"text","marks":[{"type":"highlight"},{"type":"italic"}],"text":" *"},{"type":"text","marks":[{"type":"highlight"}],"text":")&address, 0, sizeof(address));                                             "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"address.sin_family = AF_INET;                                 "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"address.sin_addr.s_addr = htonl(INADDR_ANY);                  "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"address.sin_port = htons(8080);                               "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"if (bind(server_fd, (struct sockaddr *)&address,               sizeof(address)) < 0) {                                       "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    perror(“bind failed”);                                    "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    return 0;                                                 "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"}                                                             "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The htonl and htons functions convert a long integer (address) and a short integer (port) respectively into a network representation."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"aUm2yxSV","typeName":"shape"},{"x":1078.499072365791,"y":814.3368976431026,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:NdRE26qklGKbM0aGfiWSW","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"A socket, "},{"type":"text","marks":[{"type":"bold"}],"text":"server_fd"},{"type":"text","text":", is created with the socket system call:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"int server_fd = socket(domain, type, protocol);"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"All the parameters as well as the return value are integers:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"domain (address family)"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Communication domain in which the socket should be created. Some of address families are:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"AF_INET"},{"type":"text","text":" (IP) & "},{"type":"text","marks":[{"type":"bold"}],"text":"AF_INET6"},{"type":"text","text":" (IPv6)"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"AF_UNIX"},{"type":"text","text":" (local channel, similar to pipes)"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"AF_ISO"},{"type":"text","text":" (ISO protocols)"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"AF_NS"},{"type":"text","text":" (Xerox Network Systems protocols)"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"AF_NDD"},{"type":"text","text":" (Network Device Drivers of the operating system)"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"You can read all about address families "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.ibm.com/docs/en/aix/7.2.0?topic=domains-address-families","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"here"},{"type":"text","text":", but for now, we will focus on "},{"type":"text","marks":[{"type":"bold"}],"text":"AF_INET"},{"type":"text","text":", which is the address family used for internet connections."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"type"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Type of service. It is selected according to the properties required by the application:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"SOCK_STREAM"},{"type":"text","text":" (virtual circuit service)"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"SOCK_DGRAM"},{"type":"text","text":" (datagram service)"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"SOCK_RAW"},{"type":"text","text":" (direct IP service)"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Learn more about socket types "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.ibm.com/docs/en/aix/7.2.0?topic=protocols-socket-types","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"here"},{"type":"text","text":", but essentially "},{"type":"text","marks":[{"type":"bold"}],"text":"SOCK_STREAM"},{"type":"text","text":" is the type supported by TCP, "},{"type":"text","marks":[{"type":"bold"}],"text":"SOCK_DGRAM"},{"type":"text","text":" is the type supported by UDP, and "},{"type":"text","marks":[{"type":"bold"}],"text":"SOCK_RAW"},{"type":"text","text":" is the type used for direct access to network interfaces."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=>"},{"type":"text","marks":[{"type":"bold"}],"text":" protocol:"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Indicate a specific protocol to use in supporting the sockets operation. This is useful in cases where some families may have more than one protocol to support a given type of service."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"For our use case, we want to specify the IP address family "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"AF_INET"},{"type":"text","marks":[{"type":"code"}],"text":" for"},{"type":"text","text":" IPv4, and "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"SOCK_STREAM"},{"type":"text","marks":[{"type":"code"}],"text":" for TCP"},{"type":"text","text":". Since there are no variations of the protocol, the last argument will be zero. Our code for creating a TCP socket looks like this:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"#include <sys/socket.h>                                      "},{"type":"hardBreak","marks":[{"type":"highlight"},{"type":"code"}]},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"                                                             "},{"type":"hardBreak","marks":[{"type":"highlight"},{"type":"code"}]},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"if ((server_fd = socket(AF_INET, SOCK_STREAM, 0)) < 0)       "},{"type":"hardBreak","marks":[{"type":"highlight"},{"type":"code"}]},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"{                                                            "},{"type":"hardBreak","marks":[{"type":"highlight"},{"type":"code"}]},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"    perror(“cannot create socket”);                          "},{"type":"hardBreak","marks":[{"type":"highlight"},{"type":"code"}]},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"    return 0;                                                "},{"type":"hardBreak","marks":[{"type":"highlight"},{"type":"code"}]},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"}                                                            "}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b06JrZafV","typeName":"shape"},{"x":1123.2557000020413,"y":3857.120827378784,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:MaWpTsEPHN1SjN2WRvKqH","type":"geo","props":{"w":568,"h":1,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"m","font":"mono","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"agj5bbfV","typeName":"shape"},{"x":267.3843496721848,"y":478.71195712860174,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:EihCeYfQx8OyjMNRO8XtJ","type":"text","props":{"color":"black","size":"s","w":678.1373134722685,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Listening: A running web server typically sits idle, waiting for incoming requests to handle, if no requests coming, the server doesn't do anything. But what exactly is the web server listening to?"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Port: A web server will be listening on a networking port that is provided by the operating system (there exist 65535 or 2^16-1 ports on most systems) on which it is running. The server can listen on one or multiple ports depending on its configuration."}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Request and protocol: What sending a request to a web server essentially asking for a piece of data from a server, through the port it's listening to. Servers and clients may use different kinds of protocols in the Application layer of the TCP (Transmission Control Protocol) model; protocols such as HTTP (Hypertext Transfer Protocol), which is used for communicating text-based data, FTP (File Transfer Protocol) which extends to other file types, or SCP (Secure Copy Protocol) which operates over SSH to securely copy files between machines. We will be focusing on HTTP (and HTTPS) since that's typically the only protocol used by web servers to transfer webpages or API elements."}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Response and resource: What happens next is the server returns a response. In the context of HTTP, it returns an HTTP response in the same format as the request, but containing hopefully the text data we requested."}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"}}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"a81ZZQzG","typeName":"shape"},{"x":2787.768097640552,"y":565.1354988015248,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:zlPtjSRcHr0acwN1012lT","type":"text","props":{"color":"black","size":"s","w":77.11097457566893,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Version"}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b1Yd8zGbl","typeName":"shape"},{"x":5762.748308011586,"y":2362.814231588708,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:q_in2_rLjn-NYHQFwFGCE","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Normally, and depending on what the server has implemented, it just ignores headers it doesn't recognize. Here's a list of the ones we should care about:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Host"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Specifies which virtual host the client is requesting. Used for routing between multiple websites."}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Connection"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Usually "},{"type":"text","marks":[{"type":"code"}],"text":"keep-alive"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"close"},{"type":"text","text":". For handling persistent or one-shot connections."}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Content-Length"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Size of body in bytes. Required for reading POST/PUT request bodies."}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Content-Type"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Type of request body (e.g., "},{"type":"text","marks":[{"type":"code"}],"text":"text/html"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"code"}],"text":"multipart/form-data"},{"type":"text","text":"). POST/PUT request parsing."}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Accept"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"What MIME types the client prefers. Optional, rarely enforced."}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"User-Agent"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Identifies the client. Optional, usually just logged."}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"If-Modified-Since"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"For conditional GETs (cache validation). Enables "},{"type":"text","marks":[{"type":"code"}],"text":"304 Not Modified"},{"type":"text","text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"And this is a list of the headers we must be able to send back to the client:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Date"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Current date/time (GMT). Always included"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":