 out the necessary fields and headers, we must starting reading the output stream into the body of out response object, before finally compiling the body of our response into a string that we will return back to the client."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3sXULm2l","typeName":"shape"},{"x":3400.7933670785706,"y":1548.6743081244708,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:ZuRbcJv0dxU9CMDAFwf7Y","type":"geo","props":{"w":666.9723988583446,"h":74.86424885144697,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2DKSgI0V","typeName":"shape"},{"x":1076.5121519448417,"y":861.2659804943041,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:XsgpRRbNDlVbxZGgvINvm","type":"geo","props":{"w":509.67227382958004,"h":24.826354145262826,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b0ARdV3lV","typeName":"shape"},{"x":5764.22140505281,"y":700.3088507977928,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:8QfU-_609WsSVq5CUz8dx","type":"geo","props":{"w":661.2294087635574,"h":218.4963575896801,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3HU3BGll","typeName":"shape"},{"x":2789.5329146526497,"y":656.0588464445095,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:Lar6U3qSFbK6L5nqkgDTD","