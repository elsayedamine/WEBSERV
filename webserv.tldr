ext":{"type":"doc","content":[{"type":"orderedList","attrs":{"start":4,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Creating the response"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"}}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b214XVtZV","typeName":"shape"},{"x":5765.538567539304,"y":432.06245874513826,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:_vtKJynk5T0lbVCevoHZg","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"We learned about MIME types and where they come into play in HTTP, but how do we set the MIME type for the response?"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"A simple and effective way to do so is to match the MIME type with the requested resource's file extension. For example, if the requested resource is a .html file, the Content-Type value would be text/html."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"We do this by creating a map where the keys are the commonly used file types and the values are their corresponding MIME types."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"static const std::map<std::string, std::string> mimeTypes = {"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    // Text                                                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    {\".html\", \"text/html\"},                                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    {\".htm\", \"text/html\"},                                   "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    {\".css\", \"text/css\"},                                    "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    {\".csv\", \"text/csv\"},                                    "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    {\".txt\", \"text/plain\"},                                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    ...                                                      "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"}                                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"If the requested file doesn't match any of the MIME types in the map, we use the default type: "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"application/octet-stream"},{"type":"text","marks":[{"type":"code"}],"text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"link","attrs":{"href":"https://developer.mozilla.org/en-US/docs/Web/HTTP/Guides/MIME_types/Common_types","target":"_blank","rel":"noopener noreferrer nofollow","class":null}},{"type":"code"}],"text":"Here"},{"type":"text","marks":[{"type":"code"}],"text":" is a list of the common MIME types used in HTTP."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3GC2GDDV","typeName":"shape"},{"x":3605.9528065937343,"y":180.60713810573344,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:YB_t8WavWoCjkkdwWE7ht","type":"text","props":{"color":"black","size":"m","w":260.20001220703125,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Configuration file"}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b26TcpnQV","typeName":"shape"},{"x":263.64827380052606,"y":1127.4480365274064,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:8SWzsBhcOPyj8GTZs9WTc","type":"text","props":{"color":"black","size":"m","w":263.79998779296875,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"orderedList","attrs":{"start":3,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Roadmap content"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"}}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"a9IVAyMV","typeName":"shape"},{"x":1087.6270222068374,"y":547.4263518036615,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:rQZiPQeTbQfgnKun3jpLh","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"There are a few steps involved in using sockets:"}]},{"type":"orderedList","attrs":{"start":1},"content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Create the socket"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Identify the socket (name it)"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"On the server, wait for an incoming connection"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Send and receive messages"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Close the socket"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"We will look at each one of these step carefully."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b030StkHV","typeName":"shape"},{"x":1068.966055907425,"y":1246.4490498775963,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:PEmVmRptMPVT3rp1XZIa3","type":"geo","props":{"w":665.8862689510295,"h":255.3757375546959,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b08YtwI5V","typeName":"shape"},{"x":4962.632982992069,"y":1511.0420691399108,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:4nLf--1AjV233laAWIiIn","type":"text","props":{"color":"black","size":"m","w":436.6000061035156,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"orderedList","attrs":{"start":4,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Responding to a CGI request"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"}}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3g5N7ohV","typeName":"shape"},{"x":1067.6591515002892,"y":3248.3980259106615,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:79JA8xZpEAdHuQle-hrV5","type":"geo","props":{"w":670.3335674598583,"h":110.19878592449501,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"pag