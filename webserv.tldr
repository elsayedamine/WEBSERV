"}],"text":"\t    values.push_back(value);                       "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t}                                                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tvoid addChild(const Directive& child) {            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t    children.push_back(child);                     "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t}                                                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t\t\t\t\t\t\t   "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t// Getters                                         "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tstd::string& getName() const {return name;}        "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tstd::vector<std::string> &getValues() const {      "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t    return values;                                 "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t}                                                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tstd::vector<Directive> &getChildren() const {      "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t    return children;                               "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t}                                                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t\t\t\t\t\t\t   "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"};                                                         "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"private members"},{"type":"text","text":":"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"name"},{"type":"text","text":": a string containing the name of the directive"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"values"},{"type":"text","text":": a vector containing the value of the directive"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"children"},{"type":"text","text":": an optional vector containing the sub-directives if the current one is a block."}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"public members"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The class has two constructors, one of which takes the name of the directive; getters and setters for the three private members, and some helper functions."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Here's the object representation for the example config file above:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"Directive(\"server\")                                      "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"│                                                        "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"├── Directive(\"listen\", [\"127.0.0.1:8080\"])              "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"├── Directive(\"server_name\", [\""},{"type":"text","marks":[{"type":"highlight"},{"type":"link","attrs":{"href":"http://example.com","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"example.com"},{"type":"text","marks":[{"type":"highlight"}],"text":"\"])            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"├── Directive(\"error_page\", [\"404\", \"/errors/404.html\"]) "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"├── Directive(\"client_max_body_size\", [\"10M\"])           "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"│                                                        "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"├── Directive(\"location\", [\"/\"])                         "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"│   ├── Directive(\"root\", [\"/var/www/example\"])          "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"te