parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2MXAna5V","typeName":"shape"},{"x":1119.2669316571548,"y":742.6303150322361,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:KigkTJ1VZ8Dw9cdNsQwQS","type":"geo","props":{"w":568,"h":1,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"m","font":"mono","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b04mh2HlV","typeName":"shape"},{"x":1128.6783007169652,"y":5058.256984321869,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:6AwcwxB2tjOXHBMk2XfOG","type":"geo","props":{"w":568,"h":1,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"m","font":"mono","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"aqRdqSDV","typeName":"shape"},{"x":4974.454889414825,"y":305.17428717326794,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:F9SWkNChY6j4ogKxgEh4N","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"A CGI (Common Gateway Interface) is a set of standards that define how information is exchanged between the web server and a custom script. Instead of requesting a file or a resource from the server, we request that a script be run, which would dynamically generate content for the client."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"It is pretty simple to implement and won't take much."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3SEJtJJV","typeName":"shape"},{"x":1056.1537310226074,"y":3881.843772704037,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:HuotdcPHpwDcKGkXO7tNT","type":"text","props":{"color":"black","size":"m","w":605.7999877929688,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Step 3: Waiting for an incoming connection"}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"ahpMi6rV","typeName":"shape"},{"x":3400.7933670785706,"y":1450.842739786565,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:JdJEFtKKPh2oSwBD0srM6","type":"geo","props":{"w":666.9723988583446,"h":74.86424885144697,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2CmzuFeG","typeName":"shape"},{"x":4974.420061609511,"y":619.8895771536525,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:qfAE0sDFTpQe5nL5Y1Shw","type":"geo","props":{"w":260.5093651194229,"h":121.7550616854353,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3YOOTwjV","typeName":"shape"},{"x":1232.7715674326946,"y":3276.1710972757905,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:3UDFvODlhQA8bTpjJnOsS","type":"geo","props":{"w":281.8457028145158,"h":25.478095899778054,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b0Lt1FHEV","typeName":"shape"},{"x":3399.6042855557384,"y":1234.917568468961,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:HBARI7xx-wfUVR5TRwgKP","type":"geo","props":{"w":666.9723988583446,"h":49.27753097845607,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2FU0JO1l","typeName":"shape"},{"x":1079.3682751147105,"y":545.8732994044598,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:msIA8YXuIqZFRiL3mnx5f","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"There are a few steps involved in using sockets:"}]},{"type":"orderedList","attrs":{"start":1},"content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Create the socket"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Identify the socket (name it)"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"On the server, wait for an incoming connection"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Send and receive messages"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Close the socket"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"We will look at each one of these step carefully."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"aIzhXnYl","typeName":"shape"},{"x":1056.3560470623797,"y":4726.260476845085,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:tF1irCfQTe5Wmunmc-ntj","type":"text","props":{"color":"black","size":"m","w":548.2000122070312,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Step 4: Sending and receiving messages"}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"anGBx1jV","typeName":"shape"},{"x":4980.4465342212625,"y":1557.21078562098,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:v4a97rsoTYR7WyLh15KHP","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"In order to respond to a CGI request, run the selected script inside a child process."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"we first create a pipe between the main process and the child process to read from and write to the output and the input of the script respectively."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Here's an example of how to handle a GET request"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"int fd[2];                                                   "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"if (pipe(fd) == -1) {                                        "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    perror(\"pipe\");                                          "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    return 1;                                                "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"}                                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"pid_t pid = fork();                                          "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"if (pid == -1) {                                             "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    perror(\"fork\");                                          "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    return 1;                                                "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"}                                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"if (pid == 0) {                                              "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    close(fd[0]);                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    dup2(fd[1], STDOUT_FILENO);                              "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    close(fd[1]);                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    char *argv[] = {\"/usr/bin/python3\", \"./"},{"type":"text","marks":[{"type":"highlight"},{"type":"link","attrs":{"href":"http://hello.py","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"hello.py"},{"type":"text","marks":[{"type":"highlight"}],"text":"\", NULL}; "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    execve(argv[0], argv, environ);                          "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    perror(\"execve\");                                        "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    exit(1);                                                 "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"}                                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"close(fd[1]);                                                "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"close(fd[0]);                                                "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"waitpid(pid, NULL, 0);                                       "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"return 0;                                                    "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Note that some scripts might require environment variables to be set before being run. For that, we use the "},{"type":"text","marks":[{"type":"bold"}],"text":"setenv"},{"type":"text","text":" syscall, which sets environment variables"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"int setenv(const char name, const char value, int overwrite)"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"name"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"name of the variable to set"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"value"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"value of the variable"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"overwrite"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"boolean that decided whether or not to overwrite the variable if it already exists."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The most prominent environment variable in CGI is "},{"type":"text","marks":[{"type":"bold"}],"text":"REQUEST_METHOD"},{"type":"text","text":". To set it, we use:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"setenv(\"REQUEST_METHOD\", \"GET\", 1);"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Another great example for this are query URIs, which are very commonly used in CGI requests and are formatted as such:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"/cgi-bin/"},{"type":"text","marks":[{"type":"highlight"},{"type":"link","attrs":{"href":"http://hello.py","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"hello.py"},{"type":"text","marks":[{"type":"highlight"}],"text":"?name=Ace&age=21"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"I didn't consider these types of queries in the HTTP section of this document mostly because up until now, our server only serves static pages, which makes this type of URI useless because we'd be ignoring them. But for CGI, they become very much useful, because they indicate the environment variables to be considered when executing the script."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"To add the environment variable for the query string in the example above, we use the following call:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"setenv(\"QUERY_STRING\", \"name=Ace&age=21\", 1);"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"We must not forget that the point of a script is to handle the request almost entirely using the script, meaning the work done on the parent side is minimal because the script must know how to handle it."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3haOzzQd","typeName":"shape"},{"x":2031.2618781956758,"y":974.7290307149945,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:3O8GKvb9Cse9ogDHIUmDj","type":"image","index":"b0rxWrwvn","parentId":"page:vjUhjWqdOVlf272RqSZx4","props":{"w":32.296447331617856,"h":59.819273