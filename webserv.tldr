gn":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2HIUfG0G","typeName":"shape"},{"x":3370.1121908093914,"y":118.12159414324697,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:xTS25M6ous3nRMOuHhuJv","type":"geo","props":{"w":748.2222222222224,"h":3918.0603823935344,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"solid","size":"m","font":"mono","align":"start","verticalAlign":"end","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b24FN7m2V","typeName":"shape"},{"x":2629.382008105783,"y":967.588830977458,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:UijXSsawoXQK57sHq72s4","type":"geo","props":{"w":423.5231146793976,"h":25.62200357390247,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b1mpMQqwV","typeName":"shape"},{"x":1073.0426236260746,"y":5124.930738373449,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:sjmt1_PnJpF876EER5nc4","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Again, sockets are simply FDs, so to close them, we use the same method for closing regular files:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"close(new_socket);"}]},{"type":"paragraph","attrs":{"dir":"auto"}}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"asDtA8zl","typeName":"shape"},{"x":4