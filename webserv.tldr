"attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The second parameter, "},{"type":"text","marks":[{"type":"code"},{"type":"italic"}],"text":"backlog"},{"type":"text","text":", defines the maximum number of pending connections that can be queued up before connections are refused."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"code"},{"type":"italic"}],"text":"accept"},{"type":"text","text":" system call grabs the first connection request on the queue of pending connections (set up in "},{"type":"text","marks":[{"type":"code"},{"type":"italic"}],"text":"listen"},{"type":"text","text":") and creates a new socket for that connection and returns it."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"int accept(int socket, struct sockaddr restrict"},{"type":"text","marks":[{"type":"highlight"},{"type":"italic"}],"text":" *"},{"type":"text","marks":[{"type":"highlight"}],"text":"address"},{"type":"text","marks":[{"type":"highlight"},{"type":"italic"}],"text":", "},{"type":"text","marks":[{"type":"highlight"}],"text":"socklen_t"},{"type":"text","marks":[{"type":"highlight"},{"type":"italic"}],"text":" *"},{"type":"text","marks":[{"type":"highlight"}],"text":"restrict address_len);                         "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"italic"}],"text":"accept"},{"type":"text","text":" system call is blocking, it blocks until a connection is present in the queue. Its syntax is the same as "},{"type":"text","marks":[{"type":"italic"}],"text":"bind"},{"type":"text","text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":