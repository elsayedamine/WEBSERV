"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Web server concepts"}]}]}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"a7vii3pV","typeName":"shape"},{"x":2899.97245194999,"y":574.2683097664546,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:Ljx7c5ujH4igItfU4eBtK","type":"image","index":"b1hJTQAkV","parentId":"page:vjUhjWqdOVlf272RqSZx4","props":{"w":32.296447331617856,"h":59.819273639116204,"assetId":"asset:1442115126","playing":true,"url":"","crop":null,"flipX":false,"flipY":false,"altText":""},"typeName":"shape"},{"x":2629.516159313038,"y":3324.2379806452586,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:eCRSHMxv7RPib_BC6qZMB","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Depending on the data in the request, there is a different process for handling requests. Different verbs perform trigger different actions on the server. We will go over how to process the 4 "},{"type":"text","marks":[{"type":"bold"}],"text":"ReST"},{"type":"text","text":" (Representational State Transfer) verbs, which are "},{"type":"text","marks":[{"type":"bold"}],"text":"GET"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"bold"}],"text":"POST"},{"type":"text","text":", "},{"type":"text","marks":[{"type":"bold"}],"text":"PUT"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"bold"}],"text":"DELETE"},{"type":"text","text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"GET"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"GET"},{"type":"text","text":" requests are simple to process, they are used by the client when they want to fetch data."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"GET /index.html HTTP/1.1"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"Host: "},{"type":"text","marks":[{"type":"highlight"},{"type":"link","attrs":{"href":"http://example.com","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"example.com"},{"type":"text","marks":[{"type":"highlight"}],"text":"       "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Here, we search for the "},{"type":"text","marks":[{"type":"bold"}],"text":"/index.html "},{"type":"text","text":"resource. Depending on the configuration of the server, it could be a file, a database entry, or dynamically generated content created by a CGI, but for now let's consider it to be a file in the root directory (by default, the root directory is the same directory the server is running in, but it can be configured, we'll get to that in the config file section). If the file does exist, we read its contents into the "},{"type":"text","marks":[{"type":"bold"}],"text":"::content"},{"type":"text","text":" member of our response object."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"POST"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"POST "},{"type":"text","text":"requests work differently, instead of requesting a resource, it creates a new resource. Take for example:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"POST /users HTTP/1.1                           "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"Host: "},{"type":"text","marks":[{"type":"highlight"},{"type":"link","attrs":{"href":"http://example.com","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"example.com"},{"type":"text","marks":[{"type":"highlight"}],"text":"                              "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"Content-Type: application/json                 "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"Content-Length: 44                             "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"                                               "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"{\"name\": \"Alice\", \"email\": \""},{"type":"text","marks":[{"type":"highlight"},{"type":"link","attrs":{"href":"mailto:alice@example.com","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"alice@example.com"},{"type":"text","marks":[{"type":"highlight"}],"text":"\"}"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"This example request creates a new json resource inside the directory or collection "},{"type":"text","marks":[{"type":"bold"}],"text":"/users"},{"type":"text","text":". The server decides a naming pattern for each newly created resource and returns a response containing the status of the operation. It is preferred to include the new location of the resource in the body of the response."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"PUT"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"PUT"},{"type":"text","text":" requests are similar to "},{"type":"text","marks":[{"type":"bold"}],"text":"POST"},{"type":"text","text":" requests, instead of creating a resource under a collection, it creates a named resource with a specific path."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"PUT /users/123 HTTP/1.1                        "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"Host: "},{"type":"text","marks":[{"type":"highlight"},{"type":"link","attrs":{"href":"http://example.com","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"example.com"},{"type":"text","marks":[{"type":"highlight"}],"text":"                              "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"Content-Type: application/json                 "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"Content-Length: 46                             "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"                                               "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"{\"name\": \"Alice\", \"email\": \""},{"type":"text","marks":[{"type":"highlight"},{"type":"link","attrs":{"href":"mailto:alice@newmail.com","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"alice@newmail.com"},{"type":"text","marks":[{"type":"highlight"}],"text":"\"}"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"In this example, instead of letting the server decide what to name the resource, we give it the full path. If the path already exists, the server overwrites it, if it doesn't exist, it creates it. The response is the same as "},{"type":"text","marks":[{"type":"bold"}],"text":"POST"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=>"},{"type":"text","marks":[{"type":"bold"}],"text":" DELETE"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"DELETE "},{"type":"text","text":"is straightforward. It deletes a resource from the server."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"DELETE /users/123 HTTP/1.1"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"Host: "},{"type":"text","marks":[{"type":"highlight"},{"type":"link","attrs":{"href":"http://example.com","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"example.com"},{"type":"text","marks":[{"type":"highlight"}],"text":"         "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"This request deletes the "},{"type":"text","marks":[{"type":"bold"}],"text":"123"},{"type":"text","text":" resource in the "},{"type":"text","marks":[{"type":"bold"}],"text":"users"},{"type":"text","text":" collection. We can handle the case where the resource already doesn't exist however we like."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b1wx9lnrV","typeName":"shape"},{"x":1075.897131360946,"y":1783.1880123026795,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:cWOMdEHbWdpTSw6CcliD3","type":"geo","props":{"w":660.7344238389214,"h":172.0742989987602,"geo":"rectangle","dash":"draw",