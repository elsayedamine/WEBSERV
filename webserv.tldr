ddle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b1Bf8ptBV","typeName":"shape"},{"gridSize":10,"name":"webserv","meta":{"storageUsedPercentage":2},"id":"document:document","typeName":"document"},{"x":256.1057875975964,"y":130.96051461300522,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:dBQf3kCDi1ej25i6e6EYa","type":"geo","props":{"w":748.2222222222224,"h":1429.1303371709987,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"solid","size":"m","font":"mono","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"a18EUnHG","typeName":"shape"},{"x":4190.966916843278,"y":2645.1881925718153,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:LQYvtM2vOqEmkGv00DJlH","type":"geo","props":{"w":660.6102651037672,"h":147.85687050802926,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2tP57o6V","typeName":"shape"},{"x":4964.627829406922,"y":3415.981463841375,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:BV0CtNPprwt0Iq5jDnDqi","type":"text","props":{"color":"black","size":"m","w":393.3999938964844,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"orderedList","attrs":{"start":5,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Formulating the response"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"}}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3rie3hHV","typeName":"shape"},{"x":1851.4052867195226,"y":3232.510056269133,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:iZs058lDBlGC9Clsz4RpK","type":"geo","props":{"w":662.0101298040936,"h":875.5729503704242,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b1GuZ1ubV","typeName":"shape"},{"x":1082.3424523344984,"y":301.990767381855,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:AvRHQL4a5T9d6SOWreDEi","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"A "},{"type":"text","marks":[{"type":"bold"}],"text":"socket"},{"type":"text","text":" is the mechanism that most popular operating systems provide to give programs access to the network. It allows messages to be sent and received between applications (unrelated processes) on different networked machines. It is practically a file descriptor to a remote host that we can read from and write to. UNIX provides a bunch of system calls, macros, and structures to implement our own socket. Let's take a look at how we can achieve this."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b01YIwiNV","typeName":"shape"},{"x":4190.055692326563,"y":3525.633640267554,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:fw0tRB2P9JRFMtXpIozGM","type":"geo","props":{"w":670.3335674598583,"h":56.02747522991648,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2yAHGP0V","typeName":"shape"},{"followingUserId":null,"opacityForNextShape":1,"stylesForNextShape":{},"brush":null,"scribbles":[],"cursor":{"type":"default","rotation":0},"isFocusMode":false,"exportBackground":true,"isDebugMode":false,"isToolLocked":false,"screenBounds":{"x":0,"y":0,"w":1920,"h":933},"insets":[false,false,false,false],"zoomBrush":null,"isGridMode":false,"isPenMode":false,"chatMessage":"","isChatting":false,"highlightedUserIds":[],"isFocused":true,"devicePixelRatio":1,"isCoarsePointer":false,"isHoveringCanvas":false,"openMenus":[],"isChangingStyle":false,"isReadonly":true,"meta":{},"duplicateProps":null,"cameraState":"idle","id":"instance:instance","currentPageId":"page:vjUhjWqdOVlf272RqSZx4","typeName":"instance"},{"x":4977.97899282299,"y":2580.4778218150886,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:eFdcoqJQjB9eAe6TlVa8c","type":"geo","props":{"w":659.7122580928353,"h":46.7195494131679,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3low3lUG","typeName":"shape"},{"x":4192.277784462669,"y":1844.2365671885611,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:unWMdNkcxjnbvr3WKXzMK","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The second issue we need to tackle is that of blocking I/O. By default, the "},{"type":"text","marks":[{"type":"bold"}],"text":"socket"},{"type":"text","text":" system call creates a blocking socket, since most I/O operations are inherently blocking, even for regular files, here's how it applies to sockets:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"For a blocking"},{"type":"text","marks":[{"type":"bold"}],"text":" "},{"type":"text","text":"socket, if you call "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"read()"},{"type":"text","text":" and no data has"},{"type":"text","marks":[{"type":"bold"}],"text":" "},{"type":"text","text":"arrived yet, the program waits there until something comes in."}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"If you call "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"write()"},{"type":"text","text":" and the socket’s send buffer is full, the program waits until there’s space to send."}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Similarly, "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"accept()"},{"type":"text","text":" will block until a new client connects."}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"To fix that, we use the "},{"type":"text","marks":[{"type":"bold"}],"text":"ioctl"},{"type":"text","text":" system call."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"int ioctl(int fd, int "},{"type":"text","marks":[{"type":"highlight"},{"type":"italic"}],"text":"op"},{"type":"text","marks":[{"type":"highlight"}],"text":", ...);"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"It is a variadic function because it can have many prototypes depending on the option, but for our use case, we'll only use three arguments."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"fd"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The FD we want to control, this will be our socket FD."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"op"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The option we want to set, the option we're looking for is "},{"type":"text","marks":[{"type":"bold"}],"text":"FIONBIO"},{"type":"text","text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> third argument, we'll call it "},{"type":"text","marks":[{"type":"bold"}],"text":"val"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Similar to how "},{"type":"text","marks":[{"type":"bold"}],"text":"setsockopt"},{"type":"text","text":" works, in this case it's a pointer to a boolean integer that we'll set to 1."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Calling the system call with these parameters will look like this:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"int on = 1;                                                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t\t\t\t\t                     "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"if (ioctl(sock_fd, FIONBIO, &on) < 0) {    "},{"type":"text","marks":[{"type":"highlight"}],"text":"                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"\tperror(\"ioctl\");                   "},{"type":"text","marks":[{"type":"highlight"}],"text":"                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"\treturn (0);                        "},{"type":"text","marks":[{"type":"highlight"}],"text":"                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"}                                          "},{"type":"text","marks":[{"type":"highlight"}],"text":"                  "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"This is all we need to allow I/O operations to be non-blocking."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2lkSgn0V","typeName":"shape"},{"x":1076.72859937138,"y":812.1660957338103,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:pUqIBwuJoLsBNdEETvBYv","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"A socket, "},{"type":"text","marks":[{"type":"bold"}],"text":"server_fd"},{"type":"text","text":", is created with the socket system call:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"int server_fd = socket(domain, type, protocol);"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"All the parameters as well as the return value are integers:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"domain (address family)"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Communication domain in which the socket should be created. Some of address families are:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"AF_INET"},{"type":"text","text":" (IP) & "},{"type":"text","marks":[{"type":"bold"}],"text":"AF_INET6"},{"type":"text","text":" (IPv6)"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"AF_UNIX"},{"type":"text","text":" (local channel, similar to pipes)"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"AF_ISO"},{"type":"text","text":" (ISO protocols)"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"AF_NS"},{"type":"text","text":" (Xerox Network Systems protocols)"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"AF_NDD"},{"type":"text","text":" (Network Device Drivers of the operating system)"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"You can read all about address families "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.ibm.com/docs/en/aix/7.2.0?topic=domains-address-families","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"here"},{"type":"text","text":", but for now, we will focus on "},{"type":"text","marks":[{"type":"bold"}],"text":"AF_INET"},{"type":"text","text":", which is the address family used for internet connections."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"type"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Type of service. It is selected according to the properties required by the application:"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"SOCK_STREAM"},{"type":"text","text":" (virtual circuit service)"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"SOCK_DGRAM"},{"type":"text","text":" (datagram service)"}]}]},{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"SOCK_RAW"},{"type":"text","text":" (direct IP service)"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Learn more about socket types "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.ibm.com/docs/en/aix/7.2.0?topic=protocols-socket-types","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"here"},{"type":"text","text":", but essentially "},{"type":"text","marks":[{"type":"bold"}],"text":"SOCK_STREAM"},{"type":"text","text":" is the type supported by TCP, "},{"type":"text","marks":[{"type":"bold"}],"text":"SOCK_DGRAM"},{"type":"text","text":" is the type supported by UDP, and "},{"type":"text","marks":[{"type":"bold"}],"text":"SOCK_RAW"},{"type":"text","text":" is the type used for direct access to network interfaces."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=>"},{"type":"text","marks":[{"type":"bold"}],"text":" protocol:"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Indicate a specific protocol to use in supporting the sockets operation. This is useful in cases where some families may have more than one protocol to support a given type of service."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"For our use case, we want to specify the IP address family "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"AF_INET"},{"type":"text","marks":[{"type":"code"}],"text":" for"},{"type":"text","text":" IPv4, and "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"SOCK_STREAM"},{"type":"text","marks":[{"type":"code"}],"text":" for TCP"},{"type":"text","text":". Since there are no variations of the protocol, the last argument will be zero. Our code for creating a TCP socket looks like this:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"#include <sys/socket.h>                                      "},{"type":"hardBreak","marks":[{"type":"highlight"},{"type":"code"}]},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"                                                             "},{"type":"hardBreak","marks":[{"type":"highlight"},{"type":"code"}]},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"if ((server_fd = socket(AF_INET, SOCK_STREAM, 0)) < 0)       "},{"type":"hardBreak","marks":[{"type":"highlight"},{"type":"code"}]},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"{                                                            "},{"type":"hardBreak","marks":[{"type":"highlight"},{"type":"code"}]},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"    perror(“cannot create socket”);                          "},{"type":"hardBreak","marks":[{"type":"highlight"},{"type":"code"}]},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"    return 0;                                                "},{"type":"hardBreak","marks":[{"type":"highlight"},{"type":"code"}]},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"}                                                            "}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"aMnmdCNV","typeName":"shape"},{"x":1072.0144657085782,"y":5278.126268080389,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:ipZMwPkaTZY9AWS64OOIq","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"And with that, we have our very own socket that we can use to exchange data back and forth with a client using TCP/IP. This socket is the most essential part of creating a web server because it is the one element that will allow us to receive requests and return responses to web clients."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b0d63phnV","typeName":"shape"},{"x":1075.6527659636504,"y":4769.08133301727,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:LPDrksu6FivZVbK9DXU6e","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Since sockets are  essentially just file descriptors, we can use the same UNIX I/O system calls to read and write from it:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"char buffer[1024] = {0};                                     "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"int valread = read(new_socket ,buffer, 1024);                "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"printf(“%s\\n”,buffer);                                       "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"if(valread < 0) {                                            "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    printf(\"No bytes are there to read\");                    "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"}                                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"char *hello = \"Hello from the server\";                       "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"write(new_socket , hello , strlen(hello));                   "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"}}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"aow8IUal","typeName":"shape"},{"x":2619.2516092772717,"y":3279.2130273069943,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:2K4xDv7nteZ9glf8OcZX4","type":"text","props":{"color":"black","size":"m","w":321.3999938964844,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"orderedList","attrs":{"start":3,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Processing requests"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"}}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b1uy9g2GV","typeName":"shape"},{"x":1075.6527659636504,"y":4769.08133301727,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:-XUuKpPzm1NOzVrKSoFx7","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"s