86627478113,"y":313.13643329483534,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:fRlRSoqebIO5r9CL2lZnt","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":" Before we get to processing requests, we must first learn about HTTP responses"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"HTTP responses work in a similar way as HTTP requests, only with a few differences. Reading the definition of responses from RFC9112, the only difference that exists is the first line, which replaces the request line by a status line instead."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"This is an example of an HTTP/1.1 response:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"\t\t\t\t\t\t7\t\t"},{"type":"text","marks":[{"type":"highlight"}],"text":"HTTP/1.1 200 OK            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"\t\t\t\t\t\t\t\t"},{"type":"text","marks":[{"type":"highlight"}],"text":"Content-Type: text/html    "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"\t\t\t\t\t\t\t\t"},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"Content"},{"type":"text","marks":[{"type":"highlight"}],"text":"-Length: 85         "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"\t\t\t\t\t\t\t\t"},{"type":"text","marks":[{"type":"highlight"}],"text":"\t\t\t   "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"\t\t\t\t\t\t\t\t"},{"type":"text","marks":[{"type":"highlight"}],"text":"<html>                     "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"\t\t\t\t\t\t\t\t"},{"type":"text","marks":[{"type":"highlight"}],"text":"  <body>                   "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"\t\t\t\t\t\t\t\t"},{"type":"text","marks":[{"type":"highlight"}],"text":"    <h1>Hello World</h1>   "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"\t\t\t\t\t\t\t\t"},{"type":"text","marks":[{"type":"highlight"}],"text":"  </body>                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"\t\t\t\t\t\t\t\t"},{"type":"text","marks":[{"type":"highlight"}],"text":"</html>                    "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Like in an HTTP request, an HTTP response's most important line is the first one, which is known as the status line and it goes as follows;"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"HTTP-version status-code status-message"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"status-code"},{"type":"text","text":": A code issued by the server to convey to the client the result of their request. You can read about them "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"link","attrs":{"href":"https://en.wikipedia.org/wiki/List_of_HTTP_status_codes","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"here"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"status-message"},{"type":"text","text":": A message that accompanies the code and gives a brief description for it, they are also included in the article linked above."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"headers"},{"type":"text","text":", also become a lot more important in responses. They are fields of metadata, also in key:value pairs, that give the client information about the body content. The most important headers are Content-Type and Content-Length."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Content-Length is straightforward, it is just the char length of the content, but Content-Type follows certain guidelines to specify the media type of the content. They are called "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://developer.mozilla.org/en-US/docs/Web/HTTP/Guides/MIME_types","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"MIME"},{"type":"text","text":" (Multipurpose Internet Mail Extensions"},{"type":"text","marks":[{"type":"bold"}],"text":") "},{"type":"text","text":"types and they follow the format:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"type/subtype;parameter=value"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"type"},{"type":"text","text":" represents the general category into which the data type falls, such as "},{"type":"text","marks":[{"type":"code"}],"text":"video"},{"type":"text","text":" or "},{"type":"text","marks":[{"type":"code"}],"text":"text"},{"type":"text","text":". The "},{"type":"text","marks":[{"type":"bold"}],"text":"subtype"},{"type":"text","text":" identifies the exact kind of data of the specified type the MIME type represents. And an optional "},{"type":"text","marks":[{"type":"bold"}],"text":"parameter"},{"type":"text","text":" can be added to provide additional details."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The example above specifies the "},{"type":"text","marks":[{"type":"bold"}],"text":"text"},{"type":"text","text":" category, with an "},{"type":"text","marks":[{"type":"bold"}],"text":"html"},{"type":"text","text":" subtype, meaning the content is a text based file in html format."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"bold"}],"text":"body"},{"type":"text","text":" is the actual content of the response. Most of the time, and depending on the HTTP status code, an HTTP response will have a body containing the data requested from the server. In the example above, the body of the response is the index.html file. It corresponds with the Content-Type and Content-Length header values."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b1T7CO3XV","typeName":"shape"},{"x":1123.4580160418136,"y":4701.537531519832,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:B1uBZnaNhAS3MyDGvIcGc","type":"geo","props":{"w":568,"h":1,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"m","font":"mono","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b0UVUQQEl","typeName":"shape"},{"x":1856.026744353925,"y":2320.236864849452,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:mNhbT5ZtXw-47vqOS0Ibv","type":"geo","props":{"w":261.36296324075784,"h":49.22700424147502,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b15Or3xSV","typeName":"shape"},{"x":4979.602920177431,"y":2456.3727868193128,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:f0rvyzm0FRk0AFHcvE5Kp","type":"geo","props":{"w":649.4819025205934,"h":25.059291164906426,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3jYtecjV","typeName":"shape"},{"x":1072.97906582981,"y":3917.8665386885273,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:fr_si3d331iWE8H48Wv_4","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Before a client can connect to a server, the server should have a socket that is prepared to accept the connections. The "},{"type":"text","marks":[{"type":"code"},{"type":"italic"}],"text":"listen"},{"type":"text","text":" system call tells a socket that it should be capable of accepting incoming connections:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"int listen(int socket, int backlog);"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The second parameter, "},{"type":"text","marks":[{"type":"code"},{"type":"italic"}],"text":"backlog"},{"type":"text","text":", defines the maximum number of pending connections that can be queued up before connections are refused."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"code"},{"type":"italic"}],"text":"accept"},{"type":"text","text":" system call grabs the first connection request on the queue of pending connections (set up in "},{"type":"text","marks":[{"type":"code"},{"type":"italic"}],"text":"listen"},{"type":"text","text":") and creates a new socket for that connection and returns it."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"int accept(int socket, struct sockaddr restrict"},{"type":"text","marks":[{"type":"highlight"},{"type":"italic"}],"text":" *"},{"type":"text","marks":[{"type":"highlight"}],"text":"address"},{"type":"text","marks":[{"type":"highlight"},{"type":"italic"}],"text":", "},{"type":"text","marks":[{"type":"highlight"}],"text":"socklen_t"},{"type":"text","marks":[{"type":"highlight"},{"type":"italic"}],"text":" *"},{"type":"text","marks":[{"type":"highlight"}],"text":"restrict address_len);                         "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The "},{"type":"text","marks":[{"type":"italic"}],"text":"accept"},{"type":"text","text":" system call is blocking, it blocks until a connection is present in the queue. Its syntax is the same as "},{"type":"text","marks":[{"type":"italic"}],"text":"bind"},{"type":"text","text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"if (listen(server_fd, 3) < 0) {                              "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    perror(“In listen”);                                     "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    exit(EXIT_FAILURE);                                      "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"}                                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"if ((socket = accept(server_fd, (struct sockaddr*)&address,  (socklen_t *)&addrlen)) < 0) {                               "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    perror(\"In accept\");                                     "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"    exit(EXIT_FAILURE);                                      "},{"type":"hardBreak","marks":[{"type":"highlight"}]},{"type":"text","marks":[{"type":"highlight"}],"text":"}                                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"}}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b0QhIdK3V","typeName":"shape"},{"x":1876.906845091443,"y":766.5055223883587,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:Um9TGGcWUlsrbn0bHjLSl","type":"geo","props":{"w":568,"h":1,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"m","font":"mono","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b1DnBb3sV","typeName":"shape"},{"x":4392.614622557684,"y":178.94772557385647,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:akKVe_EBvQny4h5SIz0uB","type":"text","props":{"color":"black","size":"m","w":260.20001220703125,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Fixing our sockets"}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2X2d0euV","typeName":"shape"},{"x":1123.2557000020413,"y":3857.120827378784,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:wTU7Ur2Q_M9uEDnMPW4fd","type":"geo","props":{"w":568,"h":1,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"m","font":"mono","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b0Oj4U5Ud","typeName":"shape"},{"x":3408.145261316575,"y":2194.031983564657,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:kH0rEMrg-4yPacj8DMvZ_","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"To get started with the parsing, let's first define a class that will store our directives:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"class Directive {                                          "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    private:                                               "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tstd::string name;                                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tstd::vector<std::string> values;                   "}]},{"type":"paragraph","a