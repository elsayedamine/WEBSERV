e"},{"x":3402.298468129923,"y":1720.7491885272652,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:RhNjcNNou0AlxxOGmszLp","type":"geo","props":{"w":666.9723988583446,"h":49.27753097845607,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2JomieMV","typeName":"shape"},{"x":1853.0199938534479,"y":3134.9188455132416,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:nNWo4Zq5sw_4nH0aQ-DjD","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"After receiving an HTTP request, it'll be plain text, so we must parse its content before being able to use it. To get started, let's define a class for storing the HTTP request:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"#include <string>                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"#include <map>                                               "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"#include <iostream>                                          "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"                                                             "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"using namespace std;                                         "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"                                                             "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"class Request {                                              "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    public:                                                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tenum class Method {GET, POST, PUT, DELETE, UNKNOWN}; "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"                                                             "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    private:                                                 "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tMethod method;                                       "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tstring target;                                       "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tmap<string, string> headers;                         "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tstring body;                                         "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"                                                             "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    public:                                                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t// Constructor                                       "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tRequest(Method m, const string& t) {                 "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t    this->method = m;                                "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t    this->target = t;                                "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"        }                                                    "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"        //Setters                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tvoid setHeader(string& key, string& value) {         "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t    headers[key] = value;                            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t}                                                    "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tvoid setBody(const string& b) { body = b;}           "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"        //Getters                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tMethod getMethod() const { return method; }          "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tconst string& gettarget() const { return target; }   "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tstring getHeader(const string& key) const {          "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t    auto it = headers.find(key);                     "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t\t    return it != headers.end() ? it->second : \"\";    "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"        }                                                    "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t\t\t\tconst string& getBody() const { return body; }       "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"};                                                           "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"private members"},{"type":"text","text":":"}]},{"type":"bulletList","attrs":{"dir":"auto"},"content":[{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"method"},{"type":"text","text":": an enumerator type that defines the 4 HTTP verbs with macros, as well as an 'UNKNOWN' macro for invalid verbs"}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"target"},{"type":"text","text":": a string containing the target URI for the request"}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"headers"},{"type":"text","text":": an unordered map for storing header key:value pairs"}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"body"},{"type":"text","text":": a string for storing the optional body of the request"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"public members"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The constructor takes an "},{"type":"text","marks":[{"type":"bold"}],"text":"enum"},{"type":"text","text":" and a "},{"type":"text","marks":[{"type":"bold"}],"text":"string"},{"type":"text","text":", they are used for storing the method and the URI respectively. they are passed into the default constructor because they are required fields, the headers and body are optional, thus they can be set with the setters. Each of the fields has a getter that returns the corresponding value of the field."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The task at hand is to create an algorithm that parses the inbound string into a Request object to be later processed. In case the client sends an invalid request, the error must be handled in a the way we will describe in future sections."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b1F33NGsV","typeName":"shape"},{"x":1134.0086589186858,"y":1974.8089728921364,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:7UICxp4zEJnMkgQc37b_E","type":"geo","props":{"w":568,"h":1,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"m","font":"mono","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b0CtGY7sV","typeName":"shape"},{"x":2800.595361555169,"y":627.3534737741031,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:iJ6aQKRnppS2C22qJ4jmx","type":"geo","props":{"w":295.64521441652255,"h":223.57932347589434,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b1VLjtyqV","typeName":"shape"},{"x":5751.165974992543,"y":1063.532002096681,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:OrIhpVrRUVzK5aLs53taT","type":"text","props":{"color":"black","size":"m","w":436.6000061035156,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"orderedList","attrs":{"start":2,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"HTTP Status codes to handle"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"}}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b43i7vvtV","typeName":"shape"},{"x":1056.1537310226074,"y":3881.843772704037,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:GrQkCv1Ujvx-E-RJ3xXIP","type":"text","props":{"color":"black","size":"m","w":605.7999877929688,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Step 3: Waiting for an incoming connection"}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b0PTzN08G","typeName":"shape"},{"x":5280.550528961872,"y":179.73576173434282,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:0H2LU1DL25BnP-qXQfnr_","type":"text","props":{"color":"black","size":"m","w":44.19999694824219,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"CGI"}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3QIdJ9AV","typeName":"shape"},{"x":1070.4261494881832,"y":2548.1583590887603,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:42nlhA3F_t80stuhhdZyA","type":"geo","props":{"w":379.9996156882068,"h":195.24218020118587,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b0HDsgx2V","typeName":"shape"},{"x":4192.070101496856,"y":2946.9507872637673,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:yaXH6MMYBwUnFqemWhskB","type":"text","props":{"color":"black","size":"s","w":664.1111111111111,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Lastly, we need to figure out how to manage multiple FDs at the same time. Our previous code is only good for listening and accepting connections through one socket, but what if our web server is running multiple servers that are listening on multiple ports?"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"There are two methods that can be used to accomplish this task: "},{"type":"text","marks":[{"type":"bold"}],"text":"select"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"bold"}],"text":"poll"},{"type":"text","text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"In almost all modern implementations, it's better to use "},{"type":"text","marks":[{"type":"bold"}],"text":"poll"},{"type":"text","text":" due to its simplicity, memory flexibility, and superior scalability. "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.ibm.com/docs/en/i/7.6.0?topic=designs-example-nonblocking-io-select","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"This"},{"type":"text","text":" is an example of a "},{"type":"text","marks":[{"type":"bold"}],"text":"select"},{"type":"text","text":" implementation, and "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.ibm.com/docs/en/i/7.6.0?topic=designs-using-poll-instead-select","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"this"},{"type":"text","text":" is an example of a "},{"type":"text","marks":[{"type":"bold"}],"text":"poll"},{"type":"text","text":" implementation. Naturally, we will be using the "},{"type":"text","marks":[{"type":"bold"}],"text":"poll"},{"type":"text","text":" method."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"There are a couple of different elements that come into play here, first we must know the structure used by "},{"type":"text","marks":[{"type":"bold"}],"text":"poll"},{"type":"text","text":" to keep track of FDs"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"struct pollfd {       "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tint fd;       "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"italic"}],"text":"\t"},{"type":"text","marks":[{"type":"highlight"}],"text":"short events; "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\tshort revents;"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"};                    "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"fd"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Field for storing the file descriptor to be monitored."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"events"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Bit mask of the events we would like to track. this is an input field."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"revents"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Output field for the events that occurred for the FD."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"This structure is used in the "},{"type":"text","marks":[{"type":"bold"}],"text":"poll"},{"type":"text","text":" system call to wait for events on FDs concurrently. Here's how it works:"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"int poll(struct pollfd *fds, nfds_t nfds, int timeout);"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"fds"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"An array of "},{"type":"text","marks":[{"type":"bold"}],"text":"pollfd"},{"type":"text","text":" structs containing our sockets."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"nfds"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The number of FDs in the array."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"/=> "},{"type":"text","marks":[{"type":"bold"}],"text":"timeout"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"An amount of time in milliseconds that "},{"type":"text","marks":[{"type":"bold"}],"text":"poll"},{"type":"text","text":" waits before returning. If the specified amount is 0, it returns instantly. If the specified amount if -1, it indicates an indefinite timeout."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Read more about "},{"type":"text","marks":[{"type":"bold"}],"text":"poll"},{"type":"text","text":" "},{"type":"text","marks":[{"type":"link","attrs":{"href":"https://www.ibm.com/docs/en/i/7.6.0?topic=ssw_ibm_i_76/apis/poll.html","target":"_blank","rel":"noopener noreferrer nofollow","class":null}}],"text":"here"},{"type":"text","text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"In order to use "},{"type":"text","marks":[{"type":"bold"}],"text":"poll"},{"type":"text","text":", we must first initialize the "},{"type":"text","marks":[{"type":"bold"}],"text":"pollfd"},{"type":"text","text":" structure array. Note that the "},{"type":"text","marks":[{"type":"bold"}],"text":"nfds"},{"type":"text","text":" field doesn't have to be the exact size of the "},{"type":"text","marks":[{"type":"bold"}],"text":"fds "},{"type":"text","text":"array, just the amount of FDs there actually is; Meaning that we could statically allocate a large array size, and pass into "},{"type":"text","marks":[{"type":"bold"}],"text":"poll"},{"type":"text","text":" the amount of entries we filled in the array."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"struct pollfd fds[200];"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"\t\t       "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"int nfds = 0;          "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"After creating our sockets, binding them, making them reusable and non-blocking, and enabling them to listen, we can start adding them to the array."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"fds[i].fd = sock_fd;   "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"fds[i].events = POLLIN;"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"The "},{"type":"text","marks":[{"type":"bold"},{"type":"code"}],"text":"POLLIN"},{"type":"text","marks":[{"type":"code"}],"text":" event indicates that a file descriptor has data to be read, we use it to check whether or not a connection has been established."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Inside an infinite loop, we must call the poll function to check if any events have occurred on any of our sockets. "},{"type":"text","marks":[{"type":"bold"}],"text":"poll"},{"type":"text","text":" returns if one or more FDs have the requested events, or if the timeout expires. After "},{"type":"text","marks":[{"type":"bold"}],"text":"poll"},{"type":"text","text":" returns, we must iterate over the "},{"type":"text","marks":[{"type":"bold"}],"text":"fds"},{"type":"text","text":" array and check the "},{"type":"text","marks":[{"type":"bold"}],"text":"revents"},{"type":"text","text":" field for the events we are looking for, if the events we're looking for are triggered, we handle them accordingly."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"while (1) {                                                  "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    int rc = poll(fds, nfds, 180000);                        "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"}],"text":"    "},{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"if (rc < 0) {                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"\tperror(\"poll() failed\");                             "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"\tbreak;                                               "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"    }                                                        "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"    if (!rc) {                                               "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"\tprintf(\"poll() timed out.\");                         "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"\tbreak;                                               "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"    }                                                        "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"    current_size = nfds;                                     "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"    for (i = 0; i < current_size; i++) {                     "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"\tif(fds[i].revents == POLLIN) {                       "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"\t    /* Handle Input data */                          "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"\t}                                                    "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"    }                                                        "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"highlight"},{"type":"code"}],"text":"}                                                            "}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"Since we already have set our socket's I/O to be non-blocking, we can handle input and output concurrently while letting poll check for even more connections."}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"Fixing all these issues gives us an efficient, functional server that can handle multiple addresses and port at the same time."}]}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b2wgMBLPV","typeName":"shape"},{"x":5752.001797641039,"y":383.0300335338667,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:j56oTizZzo0GRoZwRIO3W","type":"text","props":{"color":"black","size":"m","w":307,"font":"mono","textAlign":"start","autoSize":true,"scale":1,"richText":{"type":"doc","content":[{"type":"orderedList","attrs":{"start":1,"type":null},"content":[{"type":"listItem","content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Setting MIME types"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"}}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3Fn6hGFV","typeName":"shape"},{"x":4979.09710404598,"y":1124.6353574943273,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:HUtmzNcnNPh7v2sqPTNMp","type":"geo","props":{"w":229.43936265241973,"h":50.35219305185797,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"s","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:vjUhjWqdOVlf272RqSZx4","index":"b3drgK3RV","typeName":"shape"},{"x":2017.1008588266295,"y":1047.6428616973121,"rotation":0,"isLocked":fal